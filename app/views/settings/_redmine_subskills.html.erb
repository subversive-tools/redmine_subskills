
<p>
  <label><%= t(:label_fit_success_threshold) %> (%)</label>
  <%= number_field_tag 'settings[fit_success_threshold]', @settings['fit_success_threshold'], min: 0, max: 100 %>
  <em class="info"><%= t(:text_fit_success_info) %></em>
</p>
<p>
  <label><%= t(:label_fit_warning_threshold) %> (%)</label>
  <%= number_field_tag 'settings[fit_warning_threshold]', @settings['fit_warning_threshold'], min: 0, max: 100 %>
  <em class="info"><%= t(:text_fit_warning_info) %></em>
</p>
<p>
  <label><%= t(:label_enable_endorsements) %></label>
  <%= hidden_field_tag 'settings[enable_endorsements]', 0 %>
  <%= check_box_tag 'settings[enable_endorsements]', 1, @settings['enable_endorsements'] == '1' %>
  <em class="info"><%= t(:text_enable_endorsements_info) %></em>
</p>
<p>
  <label><%= t(:label_allow_self_assessment) %></label>
  <%= hidden_field_tag 'settings[allow_self_assessment]', 0 %>
  <%= check_box_tag 'settings[allow_self_assessment]', 1, @settings['allow_self_assessment'] == '1' %>
  <em class="info"><%= t(:text_allow_self_assessment_info) %></em>
</p>
<p>
  <label><%= t(:label_default_view_mode) %></label>
  <%= select_tag 'settings[default_view_mode]', options_for_select([
    [t(:label_view_mode_all), 'all'],
    [t(:label_view_mode_split), 'split'],
    [t(:label_view_mode_members), 'members_only']
  ], @settings['default_view_mode']) %>
  <em class="info"><%= t(:text_default_view_mode_info) %></em>
</p>

<p>
  <label><%= t(:label_levels_count) %></label>
  <%= number_field_tag 'settings[levels_count]', @settings['levels_count'], min: 1, max: 20 %>
  <em class="info"><%= t(:text_levels_count_info) %></em>
</p>

<fieldset class="collapsible" style="margin-bottom: 15px;">
  <legend onclick="toggleFieldset(this);" class="icon icon-expanded"><%= t(:label_default_level_labels) %></legend>
  <div>
    <em class="info" style="display:block; margin-bottom: 10px;"><%= t(:text_default_level_labels_info) %></em>
    <% 
      labels = @settings['default_level_labels'] || {}
      if labels.is_a?(String)
        labels = labels.split("\n").map(&:strip).each_with_index.map { |l, i| [i.to_s, l] }.to_h
      end
    %>
    <% (0..20).each do |lvl| %>
      <p class="sk-level-label-setting" data-level="<%= lvl %>">
        <label><%= t(:label_level_n, level: lvl) %></label>
        <%= text_field_tag "settings[default_level_labels][#{lvl}]", labels[lvl.to_s], size: 40 %>
      </p>
    <% end %>
  </div>
</fieldset>

<script>
document.addEventListener("DOMContentLoaded", function() {
  var countField = document.getElementById("settings_levels_count");
  function updateLevelVisibility() {
    if (!countField) return;
    var maxLvl = parseInt(countField.value, 10) || 5;
    document.querySelectorAll('.sk-level-label-setting').forEach(function(p) {
      var lvl = parseInt(p.getAttribute('data-level'), 10);
      p.style.display = (lvl <= maxLvl) ? 'block' : 'none';
    });
  }
  if (countField) {
    countField.addEventListener("input", updateLevelVisibility);
    updateLevelVisibility();
  }
});
</script>

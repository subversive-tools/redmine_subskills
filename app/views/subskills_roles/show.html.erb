<% content_for :header_tags do %>
  <%= stylesheet_link_tag 'subskills', plugin: 'redmine_subskills' %>
<% end %>

<div class="contextual">
  <%= link_to '← Rollen-Übersicht', subskills_roles_path, class: 'button' %>
</div>

<h2><%= @role.name %></h2>
<p style="color:#888;font-size:0.82rem;"><%= @role.category %></p>

<!-- Anforderungs-Profil -->
<h3 class="subskills-category-title">Kompetenz-Anforderungen</h3>
<table class="list" style="max-width:700px;">
  <thead>
    <tr>
      <th>Kompetenz</th>
      <th>Kategorie</th>
      <th>Wichtigkeit</th>
    </tr>
  </thead>
  <tbody>
    <% @skills.select { |s| (@req[s.id] || 0) > 0 }.each_with_index do |skill, i| %>
      <% imp = @req[skill.id] %>
      <% info = SubskillRole::IMPORTANCE[imp] %>
      <tr class="<%= i.even? ? 'even' : 'odd' %>">
        <td><%= skill.name %></td>
        <td style="color:#888;font-size:0.82rem;"><%= skill.category %></td>
        <td>
          <span class="sk-importance-badge" style="background:<%= info[:color] %>;">
            <%= info[:label] %>
          </span>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<!-- Fit-Score Ranking -->
<h3 class="subskills-category-title" style="margin-top:24px;">Passung nach Person</h3>
<table class="list" style="max-width:600px;">
  <thead>
    <tr>
      <th>Person</th>
      <th style="width:200px;">Fit-Score</th>
      <th style="width:50px;text-align:right;">%</th>
    </tr>
  </thead>
  <tbody>
    <% @users_with_scores.each_with_index do |entry, i| %>
      <% user  = entry[:user] %>
      <% score = entry[:score] %>
      <% css   = score >= 70 ? 'fit-high' : score >= 40 ? 'fit-mid' : 'fit-low' %>
      <tr class="<%= i.even? ? 'even' : 'odd' %>">
        <td>
          <%= link_to user.name, user_skills_subskills_path(user_id: user.id) %>
        </td>
        <td>
          <div class="sk-fit-bar-bg">
            <div class="sk-fit-bar-fill <%= css %>" style="width:<%= score %>%;"></div>
          </div>
        </td>
        <td style="text-align:right;font-weight:700;" class="<%= css %>">
          <%= score %>%
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<!-- Skill-Gap Detail -->
<h3 class="subskills-category-title" style="margin-top:24px;">Skill-Gap Analyse</h3>
<div class="subskills-table-wrapper">
  <table class="list subskills-matrix">
    <thead>
      <tr>
        <th class="skill-name-col">Kompetenz (Wichtigkeit)</th>
        <% @users_with_scores.each do |entry| %>
          <th class="user-col" title="<%= entry[:user].name %>">
            <span class="sk-avatar"><%= entry[:user].name.chars.first(2).join.upcase %></span>
          </th>
        <% end %>
      </tr>
    </thead>
    <tbody>
      <% @skills.select { |s| (@req[s.id] || 0) > 0 }.each_with_index do |skill, i| %>
        <% imp = @req[skill.id] %>
        <tr class="<%= i.even? ? 'even' : 'odd' %>">
          <td class="skill-name-col">
            <%= skill.name %>
            <span class="sk-importance-dot sk-imp-<%= imp %>" title="<%= SubskillRole::IMPORTANCE[imp][:label] %>">●</span>
          </td>
          <% @users_with_scores.each do |entry| %>
            <% level = @user_skill_map.dig(entry[:user].id, skill.id) || 0 %>
            <td class="sk-level-cell sk-level-<%= level %>"
                title="<%= entry[:user].name %>: Level <%= level %>">
              <span class="sk-badge"><%= level %></span>
            </td>
          <% end %>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

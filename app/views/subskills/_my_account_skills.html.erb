<% editable    ||= false
   can_edit    ||= false
   score_map   ||= {}
   level_labels = ['–', 'Grundkenntnisse', 'Anwender', 'Fortgeschritten', 'Experte', 'Spezialist']
   level_colors = ['#aaa', '#90b8d8', '#5b9ec9', '#2e78b7', '#1a5c99', '#0d3d6b'] %>

<h3 style="margin:20px 0 8px;">Skills</h3>

<% if can_edit %>
  <p style="font-size:0.8rem;color:#888;margin-bottom:10px;">
    <a href="<%= url_for(controller: 'subskills', action: 'my_skills_current') %>">Skills bearbeiten →</a>
  </p>
<% end %>

<table style="width:100%;border-collapse:collapse;font-size:0.82rem;">
<% tree_rows.each do |row| %>
  <% skill = row[:skill]; depth = row[:depth] %>

  <% if skill.composite? %>
    <%# ── Composite / Parent skill – header row with aggregated score ── %>
    <% agg = (score_map[skill.id] || 0.0) %>
    <% agg_rounded = agg.round %>
    <% dot_color = agg_rounded > 0 ? level_colors[agg_rounded] : '#ccc' %>
    <% next if agg_rounded == 0 && tree_rows.none? { |r| r[:skill].parent_id == skill.id && (score_map[r[:skill].id] || 0) > 0 } %>
    <thead>
      <tr>
        <th style="text-align:left;padding:<%= depth == 0 ? '8px' : '4px' %> 4px 2px;
                   padding-left: <%= 4 + depth * 12 %>px;
                   font-weight:600;color:#444;font-size:<%= depth == 0 ? '0.85rem' : '0.8rem' %>;">
          <%= skill.name %>
        </th>
        <th style="text-align:center;font-size:0.75rem;color:#bbb;font-weight:normal;">
          <%= depth == 0 ? 'Level' : '' %>
        </th>
        <th style="width:54px;text-align:center;font-size:0.75rem;color:#bbb;font-weight:normal;">
          <%= depth == 0 ? 'Lernziel' : '' %>
        </th>
      </tr>
    </thead>

  <% else %>
    <%# ── Leaf skill – direct rating row ── %>
    <% us            = user_skills[skill.id] %>
    <% current_level = us&.level.to_i %>
    <% learn         = us&.learn_priority.to_i > 0 %>
    <% next if current_level == 0 && !learn %>

    <% descs_json = (1..5).each_with_object({}) { |l, h|
         h[l] = level_descs[[skill.id, l]].to_s
       }.to_json %>

    <tbody>
    <tr style="border-bottom:1px solid #f5f5f5;"
        data-current-level="<%= current_level %>"
        data-level-descs='<%= descs_json %>'>

      <td style="padding:4px 4px 2px; padding-left: <%= 4 + depth * 12 %>px;">
        <%= skill.name %>
        <div class="sk-level-desc"
             style="font-size:0.75rem;color:#bbb;padding-left:6px;margin-top:1px;min-height:1em;">
          <%= level_descs[[skill.id, current_level]] %>
        </div>
      </td>

      <% dot_color = current_level > 0 ? level_colors[current_level] : '#ccc' %>
      <td style="text-align:center;padding:4px 8px;vertical-align:top;padding-top:6px;">
        <div style="display:inline-flex;gap:4px;align-items:center;">
          <% (1..5).each do |lvl| %>
            <span title="<%= level_labels[lvl] %>"
                  style="display:inline-block;width:12px;height:12px;border-radius:50%;
                         border:2px solid <%= current_level >= lvl ? dot_color : '#ccc' %>;
                         background:<%= current_level >= lvl ? dot_color : 'transparent' %>;"></span>
          <% end %>
        </div>
      </td>

      <td style="text-align:center;padding:4px;vertical-align:top;padding-top:1px;">
        <% if learn %>
          <span style="color:#e53935;font-size:1rem;" title="Lernziel">★</span>
        <% end %>
      </td>
    </tr>
    </tbody>
  <% end %>
<% end %>
</table>

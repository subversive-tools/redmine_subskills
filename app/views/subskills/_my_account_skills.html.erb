<% editable    ||= false
   can_edit    ||= false
   score_map   ||= {}
   level_labels = ['–', 'Grundkenntnisse', 'Anwender / Basic', 'Fortgeschritten', 'Spezialist', 'Experte']
       level_colors = ['#ccc', '#e3f2fd', '#90caf9', '#50b1ff', '#1e88e5', '#0d47a1']
    my_endorsements ||= [] %>

<h3 class="sk-profile-h3">Skills</h3>

<% if can_edit %>
  <p class="sk-profile-edit-p">
    <a href="<%= url_for(controller: 'subskills', action: 'my_skills_current') %>">Skills bearbeiten →</a>
  </p>
<% else %>
  <p class="sk-profile-edit-p">
    <a href="<%= user_skills_subskills_path(user_id: user.id) %>">Vollständiges Skill-Profil ansehen →</a>
  </p>
<% end %>

<table class="sk-profile-table">
<% first_root_shown = false %>
<% tree_rows.each do |row| %>
  <% skill = row[:skill]; depth = row[:depth] %>

  <% if skill.composite? %>
    <%# ── Composite / Parent skill – header row with aggregated score ── %>
    <% agg = (score_map[skill.id] || 0.0) %>
    <% agg_rounded = agg.round %>
    <% dot_color = agg_rounded > 0 ? level_colors[agg_rounded] : '#ccc' %>
    <% next if agg_rounded == 0 && tree_rows.none? { |r| r[:skill].parent_id == skill.id && (score_map[r[:skill].id] || 0) > 0 } %>
    <thead>
      <tr>
        <th style="text-align:left;padding:<%= depth == 0 ? '8px' : '4px' %> 4px 2px;
                   padding-left:<%= 4 + depth * 12 %>px;
                   font-weight:600;color:#444;font-size:<%= depth == 0 ? '0.85rem' : '0.8rem' %>;"
        ><%= skill.name %></th>
                <th class="sk-profile-th">
          <%= (depth == 0 && !first_root_shown) ? 'Level' : '' %>
        </th>
        <th class="sk-profile-th sk-profile-th--lernziel">
          <%= (depth == 0 && !first_root_shown) ? 'Lernziel' : '' %>
        </th>
        <th class="sk-profile-th sk-profile-th--endorse">
          <%= (depth == 0 && !first_root_shown) ? 'Bestätigung' : '' %>
        </th>
      </tr>
    </thead>
    <% first_root_shown = true if depth == 0 %>

  <% else %>
    <%# ── Leaf skill – direct rating row ── %>
        <% us            = user_skills[skill.id] %>
    <% current_level = us&.level.to_i %>
    <% learn         = us&.learn_priority.to_i > 0 %>
    <% endorse_count = us ? us.endorsements.size : 0 %>
    <% next if current_level == 0 && !learn %>

    <% descs_json = (1..5).each_with_object({}) { |l, h|
         h[l] = level_descs[[skill.id, l]].to_s
       }.to_json %>

    <tbody>
    <tr class="sk-row-divider"
        data-current-level="<%= current_level %>"
        data-endorse-count="<%= endorse_count %>"
        data-level-descs='<%= descs_json %>'>

      <td style="padding:4px 4px 2px;padding-left:<%= 4 + depth * 12 %>px;">
        <%= skill.name %>
        <div class="sk-level-desc">
          <%= level_descs[[skill.id, current_level]] %>
        </div>
      </td>

      <% dot_color = current_level > 0 ? level_colors[current_level] : '#ccc' %>
      <td class="sk-td-center-top">
                        <div class="sk-flex-dots">
          <% (1..5).each do |lvl| %>
            <span title="<%= level_labels[lvl] %>"
                  class="sk-dot"
                  style="border:2px solid <%= current_level >= lvl ? dot_color : '#ccc' %>;
                         background:<%= current_level >= lvl ? dot_color : 'transparent' %>;"></span>
          <% end %>
        </div>
      </td>

      <td class="sk-td-star-col">
        <% if learn %>
          <span class="sk-star-red" title="Lernziel"></span>
        <% end %>
      </td>

      <td class="sk-td-center-top sk-td-endorse-col">
        <%# Endorsements Column %>
        <% if current_level > 0 %>
          <% endorse_count = us.endorsements.size %>
          <% i_endorsed = my_endorsements.include?(us.id) %>
          <div class="sk-endorse-wrap" style="display: flex; justify-content: center;">
            <% if User.current != user %>
              <input type="checkbox" 
                     class="sk-endorse-checkbox-only" 
                     <%= 'checked' if i_endorsed %>
                     onclick="skToggleEndorseCheckboxOnly(this, <%= skill.id %>)" 
                     title="<%= i_endorsed ? 'Bestätigung entfernen' : 'Skill bestätigen' %>" />
            <% else %>
              <div class="sk-endorse-full-btn readonly <%= 'has-count has-others' if endorse_count > 0 %>">
                <img src="/plugin_assets/redmine_subskills/images/endorse.svg" class="sk-endorse-icon" />
                <span class="sk-endorse-count"><%= endorse_count > 0 ? endorse_count : "" %></span>
              </div>
            <% end %>
          </div>
        <% end %>
      </td>
    </tr>
    </tbody>
  <% end %>
<% end %>
</table>

<script>
function skToggleEndorseProfile(btn, skillId) {
  const wrap = btn.closest('.sk-endorse-full-btn');
  const countSpan = wrap ? wrap.querySelector('.sk-endorse-count') : null;
  const tr = btn.closest('tr');
  
  // Optimistic UI update
  const isChecked = btn.checked;
  let currentCount = parseInt(countSpan?.textContent || '0', 10);
  if (isChecked) {
    currentCount++;
    if(wrap) {
      wrap.classList.add('active');
      wrap.classList.remove('has-others');
    }
    btn.title = 'Bestätigung entfernen';
  } else {
    currentCount = Math.max(0, currentCount - 1);
    if(wrap) {
      wrap.classList.remove('active');
      if (currentCount > 0) wrap.classList.add('has-others');
      else wrap.classList.remove('has-others');
    }
    btn.title = 'Skill bestätigen';
  }
  if (countSpan) countSpan.textContent = currentCount > 0 ? currentCount : "";
  if (tr) tr.setAttribute('data-endorse-count', currentCount);

  const url = '<%= toggle_endorsement_subskills_path(user_id: user.id) %>';
  const token = document.querySelector('meta[name="csrf-token"]')?.content || 
                document.querySelector('input[name="authenticity_token"]')?.value || '';

  fetch(url, {
    method: 'POST',
    headers: { 
      'Content-Type': 'application/x-www-form-urlencoded',
      'X-CSRF-Token': token, 
      'X-Requested-With': 'XMLHttpRequest' 
    },
    body: `skill_id=${skillId}`
  }).then(async r => {
      const contentType = r.headers.get('content-type');
      if (contentType && contentType.includes('application/json')) {
        const d = await r.json();
        if (r.ok && d.ok) {
          // Sync with server response
          if (countSpan) countSpan.textContent = d.count > 0 ? d.count : "";
          if (tr) tr.setAttribute('data-endorse-count', d.count);
        } else {
          alert('Fehler: ' + (d.error || 'Unbekannter Fehler'));
          // Revert optimistic update on failure (simple reload or unchecked)
          btn.checked = !isChecked;
        }
      } else {
        alert('Server-Fehler: ' + r.status);
      }
    }).catch(err => {
      console.error(err);
      btn.checked = !isChecked;
      alert('Verbindungsfehler: ' + err.message);
    });
}

function skToggleEndorseCheckboxOnly(btn, skillId) {
  const isChecked = btn.checked;
  btn.title = isChecked ? 'Bestätigung entfernen' : 'Skill bestätigen';
  
  const tr = btn.closest('tr.sk-row-divider');
  let originalCount = 0;
  if (tr) {
    originalCount = parseInt(tr.getAttribute('data-endorse-count') || '0', 10);
    const newCount = isChecked ? originalCount + 1 : Math.max(0, originalCount - 1);
    tr.setAttribute('data-endorse-count', newCount);
  }

  const url = '<%= toggle_endorsement_subskills_path(user_id: user.id) %>';
  const token = document.querySelector('meta[name="csrf-token"]')?.content || 
                document.querySelector('input[name="authenticity_token"]')?.value || '';

  fetch(url, {
    method: 'POST',
    headers: { 
      'Content-Type': 'application/x-www-form-urlencoded',
      'X-CSRF-Token': token, 
      'X-Requested-With': 'XMLHttpRequest' 
    },
    body: `skill_id=${skillId}`
  }).then(async r => {
      const contentType = r.headers.get('content-type');
      if (contentType && contentType.includes('application/json')) {
        const d = await r.json();
        if (!r.ok || !d.ok) {
          alert('Fehler: ' + (d.error || 'Unbekannter Fehler'));
          btn.checked = !isChecked;
          btn.title = btn.checked ? 'Bestätigung entfernen' : 'Skill bestätigen';
          if (tr) tr.setAttribute('data-endorse-count', originalCount);
        } else {
          // Sync with exact server count
          if (tr) tr.setAttribute('data-endorse-count', d.count);
        }
      } else {
        alert('Server-Fehler: ' + r.status);
        if (tr) tr.setAttribute('data-endorse-count', originalCount);
      }
    }).catch(err => {
      console.error(err);
      btn.checked = !isChecked;
      btn.title = btn.checked ? 'Bestätigung entfernen' : 'Skill bestätigen';
      if (tr) tr.setAttribute('data-endorse-count', originalCount);
      alert('Verbindungsfehler: ' + err.message);
    });
}
</script>

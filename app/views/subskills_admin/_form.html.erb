<% content_for :header_tags do %>
  <%= stylesheet_link_tag 'subskills', plugin: 'redmine_subskills' %>
<% end %>


<h2><%= @skill.new_record? ? t(:label_new_skill) : t(:label_edit_skill, name: @skill.name) %></h2>

<%= form_with model: @skill,
              url: @skill.new_record? ? subskills_admin_index_path : subskills_admin_path(@skill),
              html: { class: 'subskills-admin-form' },
              local: true do |f| %>

  <% if @skill.errors.any? %>
    <div class="flash error">
      <ul><% @skill.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %></ul>
    </div>
  <% end %>

  <div class="box tabular">
    <p>
      <%= f.label :name, t(:field_name), class: 'required' %>
      <%= f.text_field :name, required: true, size: 50 %>
    </p>
    <p>
      <%= f.label :parent_id, t(:label_parent_skill) %>
      <%= f.select :parent_id, @parent_options, { include_blank: t(:label_no_parent_skill) } %>
      <em class="info"><%= t(:text_only_skills_without_ratings) %></em>
    </p>
    </p>
    <p>
      <%= f.label :description, t(:label_short_description_tooltip) %>
      <%= f.text_area :description, rows: 2, cols: 60,
          placeholder: t(:text_short_description_placeholder) %>
    </p>
    <p>
      <%= f.label :active, t(:field_active) %>
      <%= f.check_box :active %>
      <em class="info"><%= t(:text_inactive_skills_hidden) %></em>
    </p>
  </div>

  <%# Level-Beschreibungen – nur für Blatt-Skills sinnvoll %>
  <% if @skill.composite? %>
    <div class="flash warning sk-flash-mt">
      <%= raw t(:text_skill_has_children_warning) %>
    </div>
  <% end %>
  <% if @skill.persisted? && @skill.user_skills.any? %>
    <div class="flash warning sk-flash-mt">
      <%= t(:text_skill_has_ratings_warning, count: @skill.user_skills.count) %><br>
      <%= t(:text_skill_has_ratings_level_warning) %>
    </div>
  <% end %>

  <% unless @skill.composite? %>
  <h3 class="sk-admin-h3"><%= t(:label_level_descriptions) %></h3>
  <p class="sk-admin-note">
    <%= t(:text_level_descriptions_note) %>
  </p>

  <div class="box tabular">

    <%= f.fields_for :level_descriptions, @skill.level_descriptions.sort_by(&:level) do |lf| %>
      <%= lf.hidden_field :level %>
      <% lvl = lf.object.level %>
      <p>
        <label class="sk-admin-level-lbl">
          <%= t(:label_level_n, level: lvl) %>
        </label>
        <%= lf.text_field :label, placeholder: SubskillUserSkill.level_label(lvl), size: 30 %>
        <br>
        <label class="sk-admin-level-lbl">&nbsp;</label>
        <%= lf.text_area :description, rows: 2, cols: 55,
            placeholder: t(:text_level_n_placeholder, level: lvl) %>
      </p>
    <% end %>
  </div>
  <% end %>

  <p>
    <%= f.submit @skill.new_record? ? t(:button_create) : t(:button_save), class: 'button-positive' %>
    <%= link_to t(:button_cancel), subskills_admin_index_path, class: 'button' %>
  </p>
<% end %>



<% content_for :header_tags do %>
  <%= stylesheet_link_tag 'subskills', plugin: 'redmine_subskills' %>
<% end %>

<h2>Best Match</h2>

<div class="contextual">
  <%= link_to '← Anforderungen', project_skills_path(@project), class: 'icon icon-list' %>
</div>

<p class="sk-intro">
  Rangfolge aller aktiven User nach Übereinstimmung mit den Skill-Anforderungen dieses Projekts.
</p>

<% if @skill_role.requirements.empty? %>
  <p class="nodata">
    Noch keine Skill-Anforderungen definiert –
    <%= link_to 'jetzt konfigurieren', edit_project_skills_path(@project) %>.
  </p>
<% else %>
  <table class="list sk-table-wide">
    <thead>
      <tr>
        <th class="sk-th-rank">#</th>
        <th><%= t(:label_person) %></th>
        <th class="sk-th-score-xl">Fit-Score</th>
        <th class="sk-th-pct">%</th>
      </tr>
    </thead>
    <tbody>
      <% @ranked_users.each_with_index do |entry, i| %>
        <% score = entry[:score] %>
        <% css   = score >= 70 ? 'fit-high' : score >= 40 ? 'fit-mid' : 'fit-low' %>
        <tr class="<%= i.even? ? 'even' : 'odd' %>">
          <td class="sk-td-rank"><%= i + 1 %></td>
          <td>
            <%= link_to entry[:user].name,
                user_skills_subskills_path(user_id: entry[:user].id) %>
          </td>
          <td>
            <div class="sk-fit-bar-bg">
              <div class="sk-fit-bar-fill <%= css %>" style="width:<%= score %>%;"></div>
            </div>
          </td>
          <td class="sk-td-pct <%= css %>">
            <%= score %>%
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <div class="subskills-legend">
    <span class="sk-legend-item fit-high">≥ 70% – Gute Passung</span>
    <span class="sk-legend-item fit-mid">40–69% – Teilweise</span>
    <span class="sk-legend-item fit-low">&lt; 40% – Lücken</span>
  </div>
<% end %>

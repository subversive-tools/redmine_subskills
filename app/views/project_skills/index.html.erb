<% content_for :header_tags do %>
  <%= stylesheet_link_tag 'subskills', plugin: 'redmine_subskills' %>
<% end %>

<% has_members = @fit_scores.any? { |fs| @user_roles_map.key?(fs[:user].id) } %>
<div class="contextual" style="display: flex; gap: 10px; align-items: center;">
  <label for="psk-view-mode" style="font-size: 0.9em; color: #555;"><%= t(:label_view_mode, default: "Darstellung:") %></label>
  <select id="psk-view-mode" class="psk-view-mode-select" onchange="pskChangeViewMode(this.value)" style="margin-right: 15px;">
    <option value="all"><%= t(:label_view_mode_all, default: "Alle (ungruppiert)") %></option>
    <option value="split"><%= t(:label_view_mode_split, default: "Mitglieder & Externe gruppiert") %></option>
    <option value="members_only" <%= 'disabled' unless has_members %>><%= t(:label_view_mode_members, default: "Nur Projektmitglieder") %></option>
  </select>

  <% if User.current.allowed_to?(:manage_subskills, @project) || User.current.allowed_to?(:manage_project, @project) || User.current.allowed_to?(:manage_members, @project) %>
    <%= link_to edit_project_skills_path(@project), class: 'icon icon-edit' do %>
      <%= sprite_icon('edit') %><span class="icon-label"><%= t(:label_edit_requirements) %></span>
    <% end %>
  <% end %>
</div>

<h2>Skills</h2>

<%# Build set of IDs to show: required skills + all their ancestors %>
<% required_ids = @req_map.select { |_id, imp| imp.to_i > 0 }.keys.to_set %>
<% all_by_id = @tree_rows.each_with_object({}) { |r, h| h[r[:skill].id] = r[:skill] } %>
<% visible_ids = required_ids.each_with_object(required_ids.dup) do |sid, set|
     node = all_by_id[sid]
     while node&.parent_id
       set << node.parent_id
       node = all_by_id[node.parent_id]
     end
   end %>
<% visible_rows = @tree_rows.select { |r| visible_ids.include?(r[:skill].id) } %>

<% if visible_rows.empty? %>
  <p class="nodata">
    Noch keine Skill-Anforderungen definiert.
    <% if User.current.allowed_to?(:manage_subskills, @project) || User.current.allowed_to?(:manage_project, @project) || User.current.allowed_to?(:manage_members, @project) %>
      <%= link_to 'Jetzt konfigurieren', edit_project_skills_path(@project) %>
    <% end %>
  </p>
<% else %>

<div class="psk-scroll">
<table class="list projects" id="psk-table">
  <thead>
    <tr>
      <th class="name"><%= t(:field_name) %></th>
      <th class="short_description"><%= t(:field_description) %></th>
      <th class="psk-th-req"><%= t(:label_requirement) %></th>
      <th class="psk-th-sort" title="<%= t(:label_sort_columns) %>">
        <a href="#" id="psk-sort-alpha-btn" class="psk-row-clickable" style="color: inherit; text-decoration: none;">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; opacity: 0.5;"><path d="M4 9h16M20 9l-4-4M20 9l-4 4M20 15H4M4 15l4-4M4 15l4 4"/></svg>
        </a>
      </th>
      <% @fit_scores.each do |fs| %>
        <th class="psk-th-user" data-user-id="<%= fs[:user].id %>" data-is-member="<%= @user_roles_map.key?(fs[:user].id) ? 'true' : 'false' %>" title="<%= fs[:user].name %>">
          <%= link_to fs[:user].firstname, user_path(fs[:user]) %><br>
          <%= link_to fs[:user].lastname, user_path(fs[:user]), class: 'psk-user-lastname' %>
        </th>
      <% end %>
    </tr>
    <%# Passung summary row — click to restore passung order %>
    <tr class="psk-passung-row psk-row-clickable" id="psk-passung-row">
      <td class="name"></td>
      <td class="short_description"></td>
      <td class="psk-passung-label"><%= t(:label_match) %></td>
      <td class="psk-td-sort"></td>
      <% @fit_scores.each do |fs| %>
        <% pct = fs[:score].to_i %>
        <% badge_cls = pct >= 80 ? 'psk-score-high' : pct >= 50 ? 'psk-score-mid' : 'psk-score-low' %>
        <td class="psk-score-cell" data-user-id="<%= fs[:user].id %>" data-is-member="<%= @user_roles_map.key?(fs[:user].id) ? 'true' : 'false' %>">
          <span class="psk-score-badge <%= badge_cls %>" title="<%= t(:label_match) %>: <%= pct %>%"><%= pct %>%</span>
        </td>
      <% end %>
    </tr>
  </thead>
  <tbody>
    <% level_labels = ['–','Grundkenntnisse','Anwender','Fortgeschritten','Experte','Spezialist'] %>
<% visible_rows.each_with_index do |row, i| %>
      <% skill = row[:skill]; depth = row[:depth]; is_root = depth == 0 %>
      <% imp_key = @req_map[skill.id] %>
      <% imp = imp_key.to_i > 0 ? SubskillProjectRole::IMPORTANCE[imp_key] : nil %>
      <% req_label = imp ? "#{(imp[:label].is_a?(Symbol) ? t(imp[:label]) : imp[:label])} (Level #{imp_key}+)" : nil %>
      <% css = "project psk-row-clickable #{is_root ? 'root parent' : "child leaf idnt idnt-#{depth}"} #{i.even? ? 'odd' : 'even'}" %>

      <tr class="<%= css %>" id="psk-row-<%= skill.id %>">
        <td class="name">
          <% if is_root %>
            <span class="expander icon-expander open"
                  onclick="pskToggle(<%= skill.id %>, this)"
                  title="<%= t(:label_toggle_expand) %>"></span>
          <% end %>
          <span class="psk-skill-name"><%= skill.name %></span>
          <% if skill.composite? && !is_root %>
            <em class="psk-aggregated">(<%= t(:label_aggregated) %>)</em>
          <% end %>
        </td>
        <td class="short_description"><%= skill.description %></td>
        <td class="psk-td-req">
          <% if imp %>
            <span class="psk-imp-badge" style="background:<%= imp[:color] %>;" title="<%= req_label %>"><%= imp[:label].is_a?(Symbol) ? t(imp[:label]) : imp[:label] %></span>
          <% end %>
        </td>
        <td class="psk-td-sort"></td>
        <% @fit_scores.each do |fs| %>
          <% entry   = skill.children.none? ? (@user_skill_map[fs[:user].id] || {})[skill.id] : nil %>
          <% lvl     = entry&.dig(:level).to_i %>
          <% star    = entry&.dig(:star) %>
          <% endorse = entry&.dig(:endorse_count).to_i %>
          <td class="psk-td-level" data-user-id="<%= fs[:user].id %>" data-is-member="<%= @user_roles_map.key?(fs[:user].id) ? 'true' : 'false' %>" data-level="<%= lvl %>">
            <% if skill.children.none? %>
              <% if lvl > 0 %>
                <% desc = @level_descs.dig(skill.id, lvl).presence %>
                <% tip  = [level_labels[lvl], desc].compact.join(': ') %>
                <% tip += " (#{endorse} Bestätigungen)" if endorse > 0 %>
                <span class="psk-level-wrap" title="<%= tip %>">
                  <span class="sk-option-btn sk-level-<%= lvl %> sk-option-btn--active"><%= lvl %></span>
                  <% if star %>
                    <span class="psk-star-badge" title="<%= t(:label_learning_goal) %>"></span>
                  <% end %>
                  <% if endorse > 0 %>
                    <span class="psk-endorse-badge" title="<%= t(:label_endorsements_count, count: endorse) %>"></span>
                  <% end %>
                </span>
              <% else %>
                <span class="psk-no-level">–</span>
              <% end %>
            <% end %>
          </td>
        <% end %>
      </tr>
    <% end %>
  </tbody>
  <tfoot>
    <tr id="psk-roles-row">
      <td class="name"><span class="psk-add-member-label"><%= t(:label_add_as_member_with_dots) %></span></td>
      <td class="short_description"></td>
      <td class="psk-td-req"></td>
      <td class="psk-td-sort"></td>
      <% @fit_scores.each do |fs| %>
        <td class="psk-td-level" data-user-id="<%= fs[:user].id %>" data-is-member="<%= @user_roles_map.key?(fs[:user].id) ? 'true' : 'false' %>">
          <div class="psk-roles-text" title="<%= @user_roles_map[fs[:user].id] %>">
            <%= @user_roles_map[fs[:user].id].presence || '–' %>
          </div>
        </td>
      <% end %>
    </tr>
    <% if @can_manage_members %>
    <tr id="psk-add-member-row">
      <td class="name"><span class="psk-add-member-label"><%= t(:label_add_as_member) %></span></td>
      <td class="short_description"></td>
      <td class="psk-td-req"></td>
      <td class="psk-td-sort"></td>
      <% @fit_scores.each do |fs| %>
        <td class="psk-td-level" data-user-id="<%= fs[:user].id %>" data-is-member="<%= @user_roles_map.key?(fs[:user].id) ? 'true' : 'false' %>">
          <a href="#" class="psk-add-member-btn"
             data-user-id="<%= fs[:user].id %>"
             data-user-name="<%= h(fs[:user].name) %>"
             title="<%= t(:label_add_user_as_member, name: h(fs[:user].name)) %>"><%= sprite_icon('add') %></a>
        </td>
      <% end %>
    </tr>
    <% end %>
  </tfoot>
</table>
</div>

<%# ── Add-member modal ─────────────────────────────────────────── %>
<% if @can_manage_members %>
<div id="psk-member-modal" style="display:none;">
  <h3 class="title"><%= t(:label_add_member) %></h3>
  <%= form_with url: project_memberships_path(@project), method: :post, local: true, id: 'psk-member-form' do |f| %>
    <%= hidden_field_tag 'membership[user_ids][]', '', id: 'psk-member-user-id' %>
    <div class="box">
      <p><strong class="psk-modal-user"></strong></p>
      <p>
        <label><%= t(:label_role) %>:</label><br>
        <select name="membership[role_ids][]" style="width:100%;">
          <% @project_roles.each do |role| %>
            <option value="<%= role.id %>"><%= role.name %></option>
          <% end %>
        </select>
      </p>
    </div>
    <p class="buttons">
      <%= submit_tag t(:button_add) %>
      <a href="#" onclick="hideModal(this); return false;"><%= t(:button_cancel) %></a>
    </p>
  <% end %>
</div>
<% end %>

<script>
(function() {
  var table = document.getElementById('psk-table');
  if (!table) return;

  /* Original user order (passung-sorted, set by server) */
    var usersData = Array.from(
    table.querySelectorAll('thead tr:first-child th[data-user-id]')
  ).map(function(th) {
    return {
      id: th.dataset.userId,
      isMember: th.dataset.isMember === 'true',
      name: th.getAttribute('title') || ''
    };
  });
  var origUserIds = usersData.map(function(u) { return u.id; });
  var memberIds = usersData.filter(function(u) { return u.isMember; }).map(function(u) { return u.id; });
  var externalIds = usersData.filter(function(u) { return !u.isMember; }).map(function(u) { return u.id; });
  var splitUserIds = memberIds.concat(externalIds);

  var currentMode = localStorage.getItem('psk-view-mode') || 'all';
  var modeSelect = document.getElementById('psk-view-mode');
  
  if (currentMode !== 'all') {
    if (currentMode === 'members_only' && memberIds.length === 0) {
      currentMode = 'all';
      localStorage.setItem('psk-view-mode', 'all');
    } else {
      if (modeSelect) modeSelect.value = currentMode;
      setTimeout(function() { applyCurrentSortAndFilter(); }, 0);
    }
  }

  window.pskChangeViewMode = function(mode) {
    currentMode = mode;
    localStorage.setItem('psk-view-mode', mode);
    applyCurrentSortAndFilter();
  };

  function updateSplitBorder() {
    table.querySelectorAll('.psk-split-border').forEach(function(el) {
      el.classList.remove('psk-split-border');
    });
    if (currentMode === 'split' && memberIds.length > 0 && externalIds.length > 0) {
      table.querySelectorAll('tr').forEach(function(row) {
        var cells = Array.from(row.children).filter(function(c) {
          return c.dataset && c.dataset.isMember === 'true';
        });
        if (cells.length > 0) {
          cells[cells.length - 1].classList.add('psk-split-border');
        }
      });
    }
  }

  function applyCurrentSortAndFilter() {
    table.classList.remove('psk-mode-members_only', 'psk-mode-split', 'psk-mode-all');
    table.classList.add('psk-mode-' + currentMode);

    if (activeRowId === 'alpha') {
      sortByName();
    } else if (activeRowId) {
      var row = document.getElementById(activeRowId);
      if (row) sortBySkill(row);
    } else {
      var ids = currentMode === 'split' ? splitUserIds.slice() : origUserIds.slice();
      if (sortDirection === -1) {
        if (currentMode === 'split') {
          var mems = ids.filter(function(uid) { return memberIds.indexOf(uid) !== -1; }).reverse();
          var exts = ids.filter(function(uid) { return memberIds.indexOf(uid) === -1; }).reverse();
          ids = mems.concat(exts);
        } else {
          ids = ids.reverse();
        }
      }
      reorderColumns(ids);
    }
  }


  var activeRowId = null;

  /* ── Moveable sort arrow ── */
  var sortArrow = document.createElement('span');
  sortArrow.className = 'psk-sort-arrow';
  sortArrow.textContent = ' →';

  var passungSortCell = document.getElementById('psk-passung-row').querySelector('.psk-td-sort');
  if (passungSortCell) passungSortCell.appendChild(sortArrow); /* start at Passung */

  function moveSortArrow(cell) {
    cell.appendChild(sortArrow);
  }

  /* ── Column reorder ── */
  function reorderColumns(orderedIds) {
    table.querySelectorAll('tr').forEach(function(row) {
      var userCells = Array.from(row.children).filter(function(c) {
        return c.dataset && c.dataset.userId;
      });
      if (!userCells.length) return;
      var map = {};
      userCells.forEach(function(c) { map[c.dataset.userId] = c; });
      userCells.forEach(function(c) { row.removeChild(c); });
      orderedIds.forEach(function(uid) { if (map[uid]) row.appendChild(map[uid]); });
    });
    updateSplitBorder();
  }

  /* ── Sort by skill level ── */
  function sortBySkill(row) {
    /* Nur direkte Kind-TDs der angeklickten Zeile lesen */
    var cells = Array.from(row.children).filter(function(c) {
      return c.dataset && c.dataset.userId;
    });
    if (!cells.length) return;
    var pairs = cells.map(function(c) {
      return { uid: c.dataset.userId, lvl: parseInt(c.dataset.level || '0') };
    });
    pairs.sort(function(a, b) {
      if (currentMode === 'split') {
        var aIsMember = memberIds.indexOf(a.uid) !== -1;
        var bIsMember = memberIds.indexOf(b.uid) !== -1;
        if (aIsMember && !bIsMember) return -1;
        if (!aIsMember && bIsMember) return 1;
      }
      if (b.lvl !== a.lvl) return sortDirection * (b.lvl - a.lvl);
      return origUserIds.indexOf(a.uid) - origUserIds.indexOf(b.uid);
    });
    reorderColumns(pairs.map(function(p) { return p.uid; }));
  }

  /* ── Sort by Name ── */
  function sortByName() {
    var sorted = usersData.slice().sort(function(a, b) {
      if (currentMode === 'split') {
        var aIsMember = memberIds.indexOf(a.id) !== -1;
        var bIsMember = memberIds.indexOf(b.id) !== -1;
        if (aIsMember && !bIsMember) return -1;
        if (!aIsMember && bIsMember) return 1;
      }
      var cmp = a.name.localeCompare(b.name);
      return sortDirection * cmp;
    }).map(function(u) { return u.id; });
    reorderColumns(sorted);
  }

  /* ── Highlight helpers ── */
  function clearActive() {
    table.querySelectorAll('.psk-row-active').forEach(function(r) {
      r.classList.remove('psk-row-active');
    });
    var btn = document.getElementById('psk-sort-alpha-btn');
    if (btn) btn.classList.remove('psk-active-sort');
  }

  /* ── Click on skill rows ── */
  table.querySelectorAll('tbody tr').forEach(function(row) {
    row.addEventListener('click', function(e) {
      if (e.target.tagName === 'A') return;
      if (activeRowId === row.id) {
        sortDirection *= -1;
        sortArrow.textContent = sortDirection === 1 ? ' →' : ' ←';
        applyCurrentSortAndFilter();
      } else {
        activeRowId = row.id;
        sortDirection = 1;
        sortArrow.textContent = ' →';
        clearActive();
        row.classList.add('psk-row-active');
        applyCurrentSortAndFilter();
        moveSortArrow(row.querySelector('.psk-td-sort'));
      }
    });
  });

  /* ── Click on alpha sort button ── */
  var alphaBtn = document.getElementById('psk-sort-alpha-btn');
  if (alphaBtn) {
    alphaBtn.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();
      if (activeRowId === 'alpha') {
        sortDirection *= -1;
        sortArrow.textContent = sortDirection === 1 ? ' →' : ' ←';
      } else {
        activeRowId = 'alpha';
        sortDirection = 1;
        sortArrow.textContent = ' →';
        clearActive();
        alphaBtn.classList.add('psk-active-sort');
        moveSortArrow(alphaBtn);
      }
      applyCurrentSortAndFilter();
    });
  }

  /* ── Click on Passung row → restore passung order ── */
  var passungRow = document.getElementById('psk-passung-row');
  if (passungRow) {
    passungRow.addEventListener('click', function() {
      if (activeRowId === null) {
        sortDirection *= -1;
        sortArrow.textContent = sortDirection === 1 ? ' →' : ' ←';
      } else {
        activeRowId = null;
        sortDirection = 1;
        sortArrow.textContent = ' →';
        clearActive();
        moveSortArrow(passungRow.querySelector('.psk-td-sort'));
      }
      applyCurrentSortAndFilter();
    });
  }

  /* ── Collapse/expand ── */
  window.pskToggle = function(rootId, expander) {
    var rows = Array.from(table.querySelectorAll('tbody tr'));
    var rootIdx = rows.findIndex(function(r) { return r.id === 'psk-row-' + rootId; });
    var open = expander.classList.contains('open');
    for (var j = rootIdx + 1; j < rows.length; j++) {
      if (rows[j].classList.contains('root')) break;
      rows[j].style.display = open ? 'none' : '';
    }
    expander.classList.toggle('open', !open);
  };
  /* ── Add-member modal ── */
  var modal = document.getElementById('psk-member-modal');
  if (modal) {
    document.querySelectorAll('.psk-add-member-btn').forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        var uid  = btn.dataset.userId;
        var name = btn.dataset.userName;
        document.getElementById('psk-member-user-id').value = uid;
        modal.querySelector('.psk-modal-user').textContent = name;
        showModal('psk-member-modal', '350px');
      });
    });
  }

  /* ── Tooltip-Fix: Hide browser tooltips on click ── */
  document.addEventListener('click', function(e) {
    // Wenn in die Tabelle geklickt wird, alle Tooltips kurz verstecken/zeigen
    if (table.contains(e.target)) {
      var titled = table.querySelectorAll('[title]');
      titled.forEach(function(el) {
        var t = el.getAttribute('title');
        if (t) {
          el.setAttribute('data-sk-title', t);
          el.removeAttribute('title');
          // Sofort wiederherstellen – der Browser hat das Fenster dann schon geschlossen
          setTimeout(function() {
            el.setAttribute('title', el.getAttribute('data-sk-title'));
          }, 50);
        }
      });
    }
  });

})();
</script>

<% end %>
